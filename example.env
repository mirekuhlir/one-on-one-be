NODE_ENV=development

# Core app and auth
BETTER_AUTH_SECRET=replace-with-a-long-random-secret
BETTER_AUTH_URL=http://localhost:4000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/one_on_one
CLIENT_ORIGIN=http://localhost:5173,https://your-frontend.example.com

# Transactional email
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=One on One <noreply@example.com>

# Social auth providers
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# Cloudflare TURN
CF_TURN_BASE_URL=https://rtc.live.cloudflare.com
CF_TURN_KEY_ID=
CF_TURN_API_TOKEN=
CF_TURN_TTL=36000
CF_TURN_TIMEOUT_MS=10000
